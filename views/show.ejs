<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Post</title>
    <link rel="stylesheet" href="/style.css" />
</head>
<body>
    <div class="container">
        <h1>Post Details</h1>

        <div class="post">
            <div class="post-header">
                <div class="post-top">
                    <div class="avatar avatar-lg" id="show-avatar" data-username="<%= post.username %>">
                        <span class="avatar-initials"><%= post.username.charAt(0).toUpperCase() %></span>
                    </div>
                    <div>
                        <p class="meta-info">Post ID: <%= post.id %></p>
                        <h3 class="user">@<%= post.username %></h3>
                    </div>
                </div>
            </div>
            
            <p class="content"><%= post.content %></p>
            
            <div class="post-actions">
                <a href="/posts" class="btn btn-cancel">← Back to Feed</a>
                <a href="/posts/<%= post.id %>/edit" class="btn btn-edit">Edit Post</a>
            </div>
        </div>
    </div>

    <script>
        const el = document.getElementById('show-avatar');
        const img = localStorage.getItem('pfp:' + el.dataset.username);
        if (img) {
            el.style.backgroundImage = `url(${img})`;
            el.style.backgroundSize = 'cover';
            el.style.backgroundPosition = 'center';
            el.querySelector('.avatar-initials').style.display = 'none';
        }
    </script>
</body>
</html>
