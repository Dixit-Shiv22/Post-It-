<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Posts</title>
    <link rel="stylesheet" href="/style.css" />
</head>
<body>
    <div class="container">
        <h1>Post It!</h1>
        
        <div class="feed">
            <% for (let post of posts){ %>
                <div class="post">
                    <div class="post-top">
                        <div class="avatar-wrap">
                            <div class="avatar" id="av-<%= post.id %>" data-username="<%= post.username %>">
                                <span class="avatar-initials"><%= post.username.charAt(0).toUpperCase() %></span>
                            </div>
                        </div>
                        <h3 class="user">@<%= post.username %></h3>
                    </div>

                    <p class="content"><%= post.content %></p>
                    
                    <div class="post-actions">
                        <a class="btn btn-detail" href="/posts/<%= post.id %>">See details</a>
                        <a class="btn btn-edit" href="/posts/<%= post.id %>/edit">Edit</a>
                        
                        <form method="POST" action="/posts/<%= post.id %>?_method=DELETE" class="delete-form">
                            <button class="btn btn-delete" type="submit">Delete</button>
                        </form>
                    </div>
                </div>
            <% } %>
        </div>

        <div class="create-post-container">
            <a class="btn btn-create" href="/posts/new">+ Create a new post</a>
        </div>
    </div>

    <script>
        // Hydrate all avatars from localStorage on page load
        document.querySelectorAll('.avatar[data-username]').forEach(el => {
            const key = 'pfp:' + el.dataset.username;
            const img = localStorage.getItem(key);
            if (img) {
                el.style.backgroundImage = `url(${img})`;
                el.style.backgroundSize = 'cover';
                el.style.backgroundPosition = 'center';
                el.querySelector('.avatar-initials').style.display = 'none';
            }
        });
    </script>
</body>
</html>
